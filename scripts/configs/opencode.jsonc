{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        // --- Tool-capable instruct models (suitable for agents) ---
        // Code — both variants use UD-Q5_K_XL weights; 32K ctx loads at ~25 GB vs ~45 GB for 220k; use 220k only when you need huge context
        "qwen3-coder-30b-32k": {
          "name": "Qwen3-Coder 30B A3B 32k (code, default)"
        },
        "qwen3-coder-30b-220k": {
          "name": "Qwen3-Coder 30B A3B 220k (code, large ctx)"
        },
        "codestral:22b": {
          "name": "Codestral 22B (code, 12 GB)"
        },
        "qwen2.5-coder:32b": {
          "name": "Qwen2.5 Coder 32B (heavy code, 19 GB)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B (fast code, 4.7 GB)"
        },
        "qwen2.5-coder:1.5b": {
          "name": "Qwen2.5 Coder 1.5B (micro code, 1 GB)"
        },
        // Think / reasoning
        "hf.co/bartowski/Mistral-Small-24B-Instruct-2501-GGUF:Q4_K_M": {
          "name": "Mistral Small 24B 2501 (think)"
        },
        "mistral-small3.2:latest": {
          "name": "Mistral Small 3.2 24B (think+vision)"
        },
        "mfdoom/deepseek-r1-tool-calling:8b": {
          "name": "DeepSeek R1 Tool-Calling 8B (reason+tools)"
        },
        // Research — 1M context
        "mistral-nemo:latest": {
          "name": "Mistral Nemo 12B 1M ctx (research)"
        },
        // Writing / general — 27B preferred over 35B to save ~6 GB of unified memory
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27B (write+vision, 17 GB)"
        },
        "qwen3.5:35b-a3b": {
          "name": "Qwen 3.5 35B A3B (write, heavy, 23 GB)"
        },
        // Fast / plan / small
        "hf.co/unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M": {
          "name": "Qwen3 4B Instruct 2507 (plan)"
        },
        "phi4-mini:latest": {
          "name": "Phi-4 Mini 4B (fast)"
        },
        "dengcao/Qwen3-14B:Q5_K_M": {
          "name": "Qwen3 14B Q5 (research)"
        },
        // --- Reasoning/thinking distills — no tool support, chat-only ---
        "hf.co/mradermacher/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-i1-GGUF:Q4_K_M": {
          "name": "Qwen3.5 27B Opus Reasoning Distill (no tools)"
        },
        "yolo0perris/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF_Q3_K_M": {
          "name": "Qwen3.5 27B Opus Reasoning Distill Q3 (no tools)"
        },
        "mradermacher/Qwen2.5-7B-Instruct-1M-Thinking-Claude-Gemini-GPT5.2-DISTILL-GGUF:Q4_K_M": {
          "name": "Qwen2.5 7B Thinking Distill (no tools)"
        },
        "deepseek-r1:8b": {
          "name": "DeepSeek R1 Qwen3 8B (no tools)"
        }
      }
    }
  },
  "default_agent": "code",
  // qwen3-coder-30b-32k: same weights as 220k but capped at 32K ctx (~21 GB vs ~38 GB loaded)
  "model": "ollama/qwen3-coder-30b-32k",
  "small_model": "ollama/hf.co/unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": "ask"
  },
  "agent": {
    "code": {
      "description": "Primary coding agent for implementation, editing, refactoring, and debugging.",
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-32k",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "ask"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly."
    },
    "think": {
      "description": "Reasoning agent for decision analysis, scoring, debugging strategy, and debriefs.",
      "mode": "primary",
      "model": "ollama/mfdoom/deepseek-r1-tool-calling:8b",
      "temperature": 0.3,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, interview answers, and evaluation decisions. Do not edit files or run commands. Produce clear structured reasoning, alternatives, and recommendations."
    },
    "write": {
      "description": "Writing agent for resumes, cover letters, documentation, summaries, and polished prose.",
      "mode": "primary",
      "model": "ollama/qwen3.5:27b",
      "temperature": 0.65,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "deny"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished resumes, cover letters, technical documentation, summaries, and interview prep materials. Avoid unnecessary verbosity and keep claims specific."
    },
    "research": {
      "description": "Research agent for company research, technical discovery, and structured findings. Saves output to Obsidian vault.",
      "mode": "primary",
      "model": "ollama/dengcao/Qwen3-14B:Q5_K_M",
      "temperature": 0.25,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "deny"
      },
      "prompt": "You are a research agent. Gather evidence, inspect files, compare options, and produce structured findings. Do not execute shell commands.\n\nAt the end of every research session, save your findings to the Obsidian vault at:\n  ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/primary/Research/\n\nName the file using the topic and today's date: `YYYY-MM-DD topic-slug.md`.\n\nStructure the file as:\n# <Topic>\n_Date: YYYY-MM-DD_\n\n## Summary\n<2-4 sentences>\n\n## Findings\n<bullet points, organized by sub-topic>\n\n## Open Questions\n<what still needs investigation>\n\n## Next Steps\n<concrete recommended actions>\n\nIf the user explicitly says not to save, skip writing the file."
    },
    "plan": {
      "description": "Fast planning agent for next steps, breakdowns, sequencing, and lightweight routing.",
      "mode": "primary",
      "model": "ollama/hf.co/unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M",
      "temperature": 0.25,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented."
    }
  }
}